[Unit]
Description=Git MCP Server — Centralized Git Operations
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/git-mcp
Environment=PATH=/home/ubuntu/.local/share/pnpm:/home/ubuntu/.nvm/versions/node/v22.23.0/bin:/usr/local/bin:/usr/bin:/bin
Environment=GIT_TOKEN=
ExecStart=/home/ubuntu/.local/share/pnpm/pnpm run dev
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
